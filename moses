nav h2 {
  margin: 0;
  color: #facc15;
}

nav ul {
  list-style: none;
  display: flex;
  gap: 15px;
}

nav ul li a {
  color: white;
  text-decoration: none;
  font-weight: bold;
  transition: 0.3s;
}

nav ul li a:hover {
  color: #facc15;
}

/* MOVING TEXT */
.ticker {
  overflow: hidden;
  white-space: nowrap;
  background: rgba(0,0,0,0.35);
  padding: 12px 0;
}

.ticker-track {
  display: inline-block;
  white-space: nowrap;
  animation: scroll 10s linear infinite;
}

.ticker-track span {
  display: inline-block;
  margin: 0 50px;
  color: #facc15;
  font-weight: 600;
}

@keyframes scroll {
  0% { transform: translateX(0%); }
  100% { transform: translateX(-50%); }
}

/* HERO */
.hero {
  text-align: center;
  padding: 60px 20px;
}

.hero h1 {
  font-size: 45px;
  background: linear-gradient(to right, #facc15, #22c55e);
  -webkit-background-clip: text;
  color: transparent;
}

.hero p {
  color: #cbd5e1;
}

/* SECTION */
.section {
  background: rgba(255,255,255,0.08);
  margin: 20px;
  padding: 25px;
  border-radius: 15px;
  backdrop-filter: blur(10px);
  line-height: 1.8;
}

/* LIST */
.section ul {
  columns: 2;
}

/* GRID */
.grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 15px;
  padding: 20px;
}

/* CARD */
.card {
  background: rgba(255,255,255,0.1);
  border-radius: 15px;
  overflow: hidden;
  text-align: center;
  transition: 0.4s;
  border: 1px solid rgba(255,255,255,0.2);
}

.card:hover {
  transform: scale(1.07);
  box-shadow: 0 10px 25px rgba(0,0,0,0.5);
}

/* ✅ FIXED IMAGE ISSUE (NO FACE CUTTING) */
.card img {
  width: 100%;
  height: 180px;

  /* KEY FIX */
  object-fit: contain;     /* prevents face cutting */
  object-position: center; /* keeps image centered */

  background: rgba(255,255,255,0.08);
}

/* TEACHER BOX */
