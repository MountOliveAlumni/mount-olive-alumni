/* NAV */
nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: rgba(0,0,0,0.45);
  padding: 15px 20px;
  backdrop-filter: blur(12px);
  position: sticky;
  top: 0;
  z-index: 100;
