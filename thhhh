/* NAV */
nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: rgba(0,0,0,0.4);
  padding: 15px 20px;
  backdrop-filter: blur(10px);
  position: sticky;
  top: 0;
  z-index: 100;
}

nav h2 {
  margin: 0;
  color: #facc15;
}

nav ul {
  list-style: none;
  display: flex;
  gap: 15px;
}

nav ul li a {
  color: white;
  text-decoration: none;
  font-weight: bold;
}

nav ul li a:hover {
  color: #facc15;
}

/* MOVING TEXT */
.marquee {
  background: rgba(0,0,0,0.3);
  overflow: hidden;
  white-space: nowrap;
  padding: 10px;
}

.marquee span {
  display: inline-block;
  padding-left: 100%;
  animation: move 12s linear infinite;
  color: #facc15;
  font-weight: bold;
}

@keyframes move {
  0% { transform: translateX(0); }
  100% { transform: translateX(-100%); }
}

/* HERO */
.hero {
  text-align: center;
  padding: 50px 20px;
}

.hero h1 {
  font-size: 40px;
}

.hero p {
  color: #cbd5e1;
}

/* SECTION */
.section {
  background: rgba(255,255,255,0.08);
  margin: 20px;
  padding: 25px;
  border-radius: 15px;
  backdrop-filter: blur(10px);
  line-height: 1.7;
}

/* GRID */
.grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 15px;
  padding: 20px;
}

/* CARD */
.card {
  background: rgba(255,255,255,0.1);
  border-radius: 15px;
  overflow: hidden;
  text-align: center;
  transition: 0.4s;
}

.card:hover {
  transform: translateY(-6px);
}

/* IMAGE FIX */
.card img {
  width: 100%;
  height: 180px;
  object-fit: cover;
}

/* TEXT */
.card h3 {
  color: #facc15;
  margin: 10px 0 5px;
}

.card p {
  font-size: 13px;
  padding: 0 10px 15px;
  color: #e2e8f0;
}

/* TEACHER BOX */
.teacher-box {
  width: 60px;
  height: 60px;
  margin: 10px auto;
  border-radius: 50%;
  background: #facc15;
  color: black;
  display: flex;
  justify-content: center;
  align-items: center;
  font-weight: 700;
  font-size: 20px;
}

/* FOOTER */
footer {
  text-align: center;
  padding: 20px;
  background: rgba(0,0,0,0.5);
  margin-top: 20px;
}

